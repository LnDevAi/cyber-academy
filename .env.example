# =============================================================================
# Cyber Academy E-DEFENCE — Environment Variables Example
# Copy this file to .env and fill in all CHANGE_ME values
# NEVER commit .env to version control
# =============================================================================

# =============================================================================
# Application
# =============================================================================
DEBUG=false
SECRET_KEY=CHANGE_ME_64_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=https://academy.edefence.tech
ALLOWED_ORIGINS=["https://academy.edefence.tech"]

# =============================================================================
# PostgreSQL Database
# =============================================================================
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://cyberacademy:CHANGE_ME@db:5432/cyberacademy
DATABASE_SYNC_URL=postgresql://cyberacademy:CHANGE_ME@db:5432/cyberacademy

# =============================================================================
# Redis
# =============================================================================
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# =============================================================================
# MinIO (S3-compatible Storage)
# =============================================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=cyberacademy
MINIO_SECRET_KEY=CHANGE_ME_MINIO
MINIO_BUCKET=cyberacademy
MINIO_USE_SSL=false

# =============================================================================
# Moodle LMS
# =============================================================================
MOODLE_ADMIN_PASSWORD=CHANGE_ME_MOODLE
MOODLE_URL=http://moodle:8080
MOODLE_TOKEN=CHANGE_ME_MOODLE_TOKEN
MOODLE_WEBHOOK_SECRET=CHANGE_ME_MOODLE_WEBHOOK_SECRET

# =============================================================================
# AI / TARGUI Chatbot (Anthropic Claude)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# ChromaDB vector store persistence path (for TARGUI RAG)
CHROMADB_PERSIST_PATH=/opt/cyberacademy/chromadb

# =============================================================================
# Payment Gateways
# =============================================================================

# CinetPay (Mobile Money — UEMOA: Orange Money, Wave, MTN MoMo)
CINETPAY_API_KEY=CHANGE_ME
CINETPAY_SITE_ID=CHANGE_ME
CINETPAY_SECRET_KEY=CHANGE_ME
CINETPAY_NOTIFY_URL=https://academy-api.edefence.tech/api/payments/cinetpay/webhook

# Stripe (International cards)
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_ID_UEMOA=CHANGE_ME
STRIPE_PRICE_ID_INTER=CHANGE_ME

# =============================================================================
# Blockchain / NFT Certificates (Polygon)
# =============================================================================
POLYGON_RPC_URL=https://polygon-rpc.com
CONTRACT_ADDRESS=0xCHANGE_ME_ERC721_CONTRACT
WALLET_PRIVATE_KEY=CHANGE_ME_POLYGON_KEY
WALLET_ADDRESS=0xCHANGE_ME_WALLET_ADDRESS
IPFS_GATEWAY=https://ipfs.io/ipfs/
PINATA_API_KEY=CHANGE_ME
PINATA_SECRET_KEY=CHANGE_ME

# =============================================================================
# Apache Guacamole (Cyber Range)
# =============================================================================
GUACAMOLE_URL=http://guacamole:8080/guacamole
GUACAMOLE_USER=guacadmin
GUACAMOLE_PASS=CHANGE_ME

# =============================================================================
# Kubernetes / Cyber Range
# =============================================================================
K8S_NAMESPACE_PREFIX=cyber-range
K8S_KUBECONFIG=/root/.kube/config
HELM_CHART_PATH=/opt/cyberacademy/cyber-range/helm/cyber-range-lab

# =============================================================================
# Email (SMTP — for notifications and certificates)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@edefence.tech
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=Cyber Academy E-DEFENCE <noreply@edefence.tech>
SMTP_TLS=true

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/2
